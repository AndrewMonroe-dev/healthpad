<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="HealthPad">
<meta name="theme-color" content="#6e1f2e">
<title>HealthPad</title>
<style>
:root{
  --paper:#f3ead4;
  --paper-2:#efe4c8;
  --vellum:#f7f0dd;
  --ink:#2a211a;
  --ink-soft:#5a4d3f;
  --ink-faint:#8a7c69;
  --wine:#6e1f2e;
  --wine-deep:#551622;
  --foil:#8a6a28;
  --foil-light:#b08d3e;
  --line:#d8c9a3;
  --line-soft:#e4d8b8;
  --leather:#3a2a20;
  --leather-2:#2c1f17;
  --good:#3f6b3a;
  --warn:#9a6a1e;
  --bad:#8a2b22;
  --shadow:rgba(60,40,20,0.18);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;padding:0;background:var(--leather-2);}
body{
  font-family:"Iowan Old Style","Palatino Linotype",Palatino,Georgia,"Times New Roman",serif;
  color:var(--ink);
  font-size:16px;
  line-height:1.45;
  -webkit-font-smoothing:antialiased;
  overscroll-behavior-y:none;
}
.app{
  max-width:560px;margin:0 auto;min-height:100vh;
  background:
    repeating-linear-gradient(0deg,transparent,transparent 31px,rgba(110,31,46,0.04) 31px,rgba(110,31,46,0.04) 32px),
    radial-gradient(circle at 20% 0%,#f7f0dd,transparent 60%),
    var(--paper);
  position:relative;padding-bottom:84px;
}
/* HEADER */
.brandbar{
  background:
    linear-gradient(180deg,var(--leather) 0%,var(--leather-2) 100%);
  color:var(--paper);
  padding:calc(env(safe-area-inset-top) + 14px) 18px 14px;
  border-bottom:3px solid var(--foil);
  box-shadow:0 2px 10px var(--shadow);
  position:relative;
}
.brandbar::after{
  content:"";position:absolute;left:0;right:0;bottom:-3px;height:3px;
  background:linear-gradient(90deg,transparent,var(--foil-light),transparent);
  opacity:.6;
}
.wordmark{font-size:26px;letter-spacing:2px;font-weight:600;margin:0;line-height:1;}
.wordmark .amp{color:var(--foil-light);}
.subwordmark{font-size:10.5px;letter-spacing:3px;text-transform:uppercase;color:var(--foil-light);margin-top:4px;opacity:.9;}
.brandrow{display:flex;justify-content:space-between;align-items:flex-end;}
.syncdot{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--foil-light);text-align:right;}
.syncdot b{display:block;font-size:15px;letter-spacing:0;color:var(--paper);}
/* SECTIONS */
.view{display:none;padding:16px 14px 8px;animation:fade .25s ease;}
.view.active{display:block;}
@keyframes fade{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:none;}}
.card{
  background:var(--vellum);
  border:1px solid var(--line);
  border-radius:8px;
  padding:14px;margin-bottom:14px;
  box-shadow:0 1px 3px var(--shadow);
  position:relative;
}
.card.foil{border:1px solid var(--foil);box-shadow:0 0 0 1px rgba(138,106,40,.25),0 1px 3px var(--shadow);}
.card-h{
  font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--wine);
  border-bottom:1px solid var(--line);padding-bottom:7px;margin-bottom:11px;font-weight:600;
  display:flex;justify-content:space-between;align-items:center;
}
.card-h .foil-tag{color:var(--foil);font-size:10px;}
h2.sec{font-size:13px;letter-spacing:2px;text-transform:uppercase;color:var(--ink-soft);margin:18px 4px 8px;font-weight:600;}
/* COUNTDOWN */
.countdown{text-align:center;padding:6px 0 2px;}
.cd-days{font-size:54px;line-height:1;color:var(--wine);font-weight:600;letter-spacing:-1px;}
.cd-label{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--ink-faint);margin-top:4px;}
.cd-date{font-size:12px;color:var(--ink-soft);margin-top:8px;font-style:italic;}
/* PROGRESS BAR */
.pbar-wrap{margin-top:12px;}
.pbar-top{display:flex;justify-content:space-between;font-size:11px;color:var(--ink-soft);margin-bottom:5px;letter-spacing:.5px;}
.pbar{height:10px;background:var(--paper-2);border:1px solid var(--line);border-radius:6px;overflow:hidden;position:relative;}
.pbar-fill{height:100%;background:linear-gradient(90deg,var(--wine),var(--wine-deep));border-radius:5px 0 0 5px;transition:width .4s;}
.pbar-fill.gold{background:linear-gradient(90deg,var(--foil),var(--foil-light));}
/* PHASE PILL */
.phase-pill{
  display:inline-block;background:var(--wine);color:var(--paper);
  font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
  padding:5px 12px;border-radius:14px;font-weight:600;
  box-shadow:0 1px 2px var(--shadow);
}
.phase-pill.deload{background:var(--foil);}
.pill{display:inline-block;font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:3px 9px;border-radius:11px;font-weight:600;margin-right:5px;}
.pill.ink{background:var(--ink);color:var(--paper);}
.pill.wine{background:var(--wine);color:var(--paper);}
.pill.gold{background:var(--foil);color:var(--paper);}
.pill.line{background:transparent;border:1px solid var(--line);color:var(--ink-soft);}
.pill.bone{background:#efe0bd;color:var(--foil);border:1px solid var(--foil);}
/* STAT GRID */
.statgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.stat{background:var(--paper);border:1px solid var(--line-soft);border-radius:7px;padding:11px 12px;text-align:center;}
.stat .v{font-size:23px;color:var(--ink);font-weight:600;line-height:1;}
.stat .v.wine{color:var(--wine);}
.stat .v.good{color:var(--good);}
.stat .l{font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-faint);margin-top:5px;}
/* INPUTS */
label.fld{display:block;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--ink-soft);margin:10px 0 4px;font-weight:600;}
input,select,textarea{
  width:100%;font-family:inherit;font-size:17px;color:var(--ink);
  background:var(--paper);border:1px solid var(--line);border-radius:6px;
  padding:11px 12px;outline:none;
}
input:focus,select,textarea:focus{border-color:var(--wine);}
input[type=number]{-moz-appearance:textfield;}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
/* BUTTONS */
.btn{
  display:block;width:100%;font-family:inherit;font-size:15px;letter-spacing:1px;
  text-transform:uppercase;font-weight:600;
  background:var(--wine);color:var(--paper);border:none;border-radius:7px;
  padding:13px;margin-top:12px;cursor:pointer;box-shadow:0 2px 5px var(--shadow);
}
.btn:active{transform:translateY(1px);}
.btn.gold{background:var(--foil);}
.btn.ghost{background:transparent;color:var(--wine);border:1px solid var(--wine);box-shadow:none;}
.btn.ink{background:var(--ink);}
.btn.sm{font-size:12px;padding:9px;margin-top:0;}
.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
/* WORKOUT */
.ex{border:1px solid var(--line);border-radius:7px;margin-bottom:10px;overflow:hidden;background:var(--paper);}
.ex-h{padding:10px 12px;background:var(--paper-2);border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;cursor:pointer;}
.ex-name{font-weight:600;font-size:15px;color:var(--ink);}
.ex-target{font-size:11px;color:var(--ink-faint);letter-spacing:.5px;margin-top:2px;}
.ex-rec{font-size:11px;color:var(--foil);font-weight:600;margin-top:3px;}
.ex-body{padding:10px 12px;display:none;}
.ex-body.open{display:block;}
.setrow{display:grid;grid-template-columns:26px 1fr 1fr 1fr;gap:7px;align-items:center;margin-bottom:7px;}
.setrow .sn{font-size:12px;color:var(--ink-faint);text-align:center;}
.setrow input{padding:8px;font-size:15px;text-align:center;}
.setlbl{display:grid;grid-template-columns:26px 1fr 1fr 1fr;gap:7px;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--ink-faint);margin-bottom:5px;padding:0 2px;}
.overload{background:#eef3e8;border:1px solid var(--good);color:var(--good);font-size:11.5px;padding:6px 9px;border-radius:5px;margin-top:6px;letter-spacing:.3px;}
/* REST TIMER */
.timer{position:fixed;bottom:96px;left:50%;transform:translateX(-50%);z-index:40;
  background:var(--leather);color:var(--paper);border:2px solid var(--foil);border-radius:30px;
  padding:10px 18px;display:none;align-items:center;gap:14px;box-shadow:0 4px 14px rgba(0,0,0,.35);}
.timer.show{display:flex;}
.timer .t{font-size:24px;font-weight:600;letter-spacing:1px;min-width:62px;text-align:center;}
.timer button{background:var(--foil);border:none;color:var(--paper);border-radius:14px;padding:6px 11px;font-family:inherit;font-size:12px;letter-spacing:1px;text-transform:uppercase;}
/* CHARTS */
.chartbox{background:var(--paper);border:1px solid var(--line);border-radius:7px;padding:10px 6px 4px;margin-top:6px;}
svg{display:block;width:100%;height:auto;}
.chart-empty{text-align:center;color:var(--ink-faint);font-style:italic;font-size:13px;padding:24px 10px;}
/* CHECK-IN */
.choices{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:6px;}
.choice{padding:11px 4px;text-align:center;border:1px solid var(--line);border-radius:7px;background:var(--paper);font-size:12px;letter-spacing:.5px;cursor:pointer;color:var(--ink-soft);}
.choice.sel{background:var(--wine);color:var(--paper);border-color:var(--wine-deep);font-weight:600;}
.choice.sel.g{background:var(--good);border-color:var(--good);}
.choice.sel.w{background:var(--warn);border-color:var(--warn);}
.choice.sel.b{background:var(--bad);border-color:var(--bad);}
/* MILESTONES */
.mile{display:flex;align-items:center;gap:11px;padding:9px 4px;border-bottom:1px solid var(--line-soft);}
.mile:last-child{border-bottom:none;}
.mile .dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--line);flex:0 0 auto;background:var(--paper);}
.mile.done .dot{background:var(--foil);border-color:var(--foil);}
.mile.done .mt{color:var(--ink);}
.mile .mt{font-size:14px;color:var(--ink-faint);}
.mile .md{font-size:11px;color:var(--ink-faint);margin-left:auto;font-style:italic;}
/* MISC */
.note{font-size:12px;color:var(--ink-soft);line-height:1.5;font-style:italic;}
.hr{height:1px;background:var(--line);margin:14px 0;border:none;}
.toast{position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--paper);padding:11px 20px;border-radius:22px;font-size:13px;letter-spacing:.5px;z-index:90;opacity:0;transition:opacity .3s;pointer-events:none;box-shadow:0 4px 12px rgba(0,0,0,.3);max-width:90%;text-align:center;}
.toast.show{opacity:1;}
.daychip{display:inline-block;font-size:11px;padding:6px 11px;border:1px solid var(--line);border-radius:14px;margin:0 6px 6px 0;background:var(--paper);color:var(--ink-soft);cursor:pointer;letter-spacing:.5px;}
.daychip.sel{background:var(--ink);color:var(--paper);border-color:var(--ink);font-weight:600;}
.daychip.rest{border-style:dashed;}
/* NAV */
.nav{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:560px;
  background:linear-gradient(180deg,var(--leather) 0%,var(--leather-2) 100%);
  border-top:3px solid var(--foil);
  display:flex;justify-content:space-around;
  padding:8px 0 calc(env(safe-area-inset-bottom) + 8px);z-index:50;
}
.navb{flex:1;text-align:center;background:none;border:none;color:var(--foil-light);font-family:inherit;cursor:pointer;padding:2px 0;opacity:.7;}
.navb.active{opacity:1;}
.navb .ic{font-size:19px;line-height:1;}
.navb .nl{font-size:9px;letter-spacing:1px;text-transform:uppercase;margin-top:3px;display:block;color:var(--foil-light);}
.navb.active .nl{color:var(--paper);}
.navb.active .ic{color:var(--paper);}
/* SPLASH */
.splash{position:fixed;inset:0;background:linear-gradient(160deg,var(--leather),var(--leather-2));z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .6s;}
.splash.hide{opacity:0;pointer-events:none;}
.splash .sw{font-size:40px;letter-spacing:4px;color:var(--paper);font-weight:600;}
.splash .sw .amp{color:var(--foil-light);}
.splash .ss{font-size:11px;letter-spacing:5px;text-transform:uppercase;color:var(--foil-light);margin-top:10px;}
.splash .crest{width:54px;height:54px;border:2px solid var(--foil);border-radius:50%;margin-bottom:22px;display:flex;align-items:center;justify-content:center;color:var(--foil-light);font-size:24px;}
small.help{display:block;font-size:11px;color:var(--ink-faint);margin-top:4px;font-style:italic;line-height:1.4;}
</style>
</head>
<body>
<div class="splash" id="splash">
  <div class="crest">&#9876;</div>
  <div class="sw"><span class="amp">HealthPad</span></div>
  <div class="ss">Strength &middot; Recomposition</div>
</div>

<div class="app">
  <div class="brandbar">
    <div class="brandrow">
      <div>
        <h1 class="wordmark"><span class="amp">HealthPad</span></h1>
        <div class="subwordmark">Campaign &middot; April 2027</div>
      </div>
      <div class="syncdot" id="syncStatus"><b id="hdrWeight">&mdash;</b>current lbs</div>
    </div>
  </div>

  <!-- HOME -->
  <div class="view active" id="v-home">
    <div class="card foil">
      <div class="card-h">The Objective <span class="foil-tag">200 LBS</span></div>
      <div class="countdown">
        <div class="cd-days" id="cdDays">&mdash;</div>
        <div class="cd-label">Days to ADT End</div>
        <div class="cd-date">Sunday, April 14, 2027</div>
      </div>
      <div class="pbar-wrap">
        <div class="pbar-top"><span>Campaign progress</span><span id="campaignPct">&mdash;</span></div>
        <div class="pbar"><div class="pbar-fill gold" id="campaignBar" style="width:0%"></div></div>
      </div>
    </div>

    <div class="card">
      <div class="card-h">Weight to Goal</div>
      <div class="statgrid">
        <div class="stat"><div class="v wine" id="homeWeight">&mdash;</div><div class="l">Current</div></div>
        <div class="stat"><div class="v" id="homeToGo">&mdash;</div><div class="l">Lbs to 200</div></div>
      </div>
      <div class="pbar-wrap">
        <div class="pbar-top"><span id="wStart">Start &mdash;</span><span>Goal 200</span></div>
        <div class="pbar"><div class="pbar-fill" id="weightBar" style="width:0%"></div></div>
      </div>
      <div class="note" id="paceNote" style="margin-top:10px;"></div>
    </div>

    <div class="card">
      <div class="card-h">Today &middot; <span id="todayPhaseTag" class="foil-tag"></span></div>
      <div style="margin-bottom:10px;">
        <span class="phase-pill" id="phasePill">&mdash;</span>
        <span class="pill line" id="weekPill" style="margin-left:6px;">&mdash;</span>
      </div>
      <div class="note" id="phaseNote"></div>
    </div>

    <div class="card">
      <div class="card-h">Morning Readiness</div>
      <label class="fld">Sleep quality</label>
      <div class="choices" data-grp="sleep">
        <div class="choice" data-v="poor">Poor</div><div class="choice" data-v="ok">OK</div><div class="choice" data-v="good">Good</div>
      </div>
      <label class="fld">Energy</label>
      <div class="choices" data-grp="energy">
        <div class="choice" data-v="low">Low</div><div class="choice" data-v="mod">Moderate</div><div class="choice" data-v="high">High</div>
      </div>
      <label class="fld">Soreness / pain</label>
      <div class="choices" data-grp="pain">
        <div class="choice" data-v="lots">Lots</div><div class="choice" data-v="some">Some</div><div class="choice" data-v="none">None</div>
      </div>
      <button class="btn sm ghost" onclick="saveReadiness()" style="margin-top:14px;">Log Readiness</button>
    </div>

    <div class="card">
      <div class="card-h">Milestones</div>
      <div id="mileList"></div>
    </div>
  </div>

  <!-- TRAIN -->
  <div class="view" id="v-train">
    <div class="card">
      <div class="card-h">Session <span class="foil-tag" id="trainPhaseTag"></span></div>
      <div id="dayChips" style="margin-bottom:6px;"></div>
      <div style="margin-bottom:8px;">
        <span class="phase-pill" id="trainDeload" style="display:none;">Deload Week &mdash; cut sets ~50%</span>
      </div>
      <div class="note" id="dayNote"></div>
    </div>

    <div class="card">
      <div class="card-h">ADT Energy Flag</div>
      <div class="choices" data-grp="fatigue">
        <div class="choice" data-v="good">Feeling Good</div>
        <div class="choice" data-v="mod">Moderate</div>
        <div class="choice" data-v="low">Low Energy</div>
      </div>
      <div class="note" id="fatigueNote" style="margin-top:9px;"></div>
    </div>

    <div id="workoutArea"></div>

    <button class="btn" onclick="saveWorkout()">Save Session to Log</button>
    <button class="btn ghost sm" onclick="startTimer(180)" style="margin-top:10px;">Rest Timer 3:00 (compound)</button>
    <button class="btn ghost sm" onclick="startTimer(90)" style="margin-top:8px;">Rest Timer 1:30 (accessory)</button>
  </div>

  <!-- LOG -->
  <div class="view" id="v-log">
    <div class="card">
      <div class="card-h">Daily Weigh-In</div>
      <label class="fld">Body weight (lbs)</label>
      <input type="number" id="inWeight" inputmode="decimal" placeholder="e.g. 232.5" step="0.1">
      <button class="btn sm" onclick="saveWeight()">Record Weight</button>
      <div class="note" id="weightEcho" style="margin-top:10px;"></div>
    </div>

    <div class="card">
      <div class="card-h">Resting Heart Rate</div>
      <label class="fld">Morning RHR (bpm)</label>
      <input type="number" id="inRHR" inputmode="numeric" placeholder="e.g. 58">
      <button class="btn sm ghost" onclick="saveRHR()">Record RHR</button>
    </div>

    <div class="card foil">
      <div class="card-h">End-of-Day Nutrition <span class="foil-tag" id="calTargetTag"></span></div>
      <label class="fld">Calories (from MyNetDiary)</label>
      <input type="number" id="inCal" inputmode="numeric" placeholder="total kcal">
      <div class="row3" style="margin-top:6px;">
        <div><label class="fld">Protein g</label><input type="number" id="inPro" inputmode="numeric" placeholder="210"></div>
        <div><label class="fld">Carbs g</label><input type="number" id="inCarb" inputmode="numeric" placeholder="g"></div>
        <div><label class="fld">Fat g</label><input type="number" id="inFat" inputmode="numeric" placeholder="g"></div>
      </div>
      <button class="btn sm" onclick="saveNutrition()">Record Day</button>
      <div class="pbar-wrap" style="margin-top:14px;">
        <div class="pbar-top"><span>Protein today</span><span id="proTop">0 / 210 g</span></div>
        <div class="pbar"><div class="pbar-fill" id="proBar" style="width:0%"></div></div>
      </div>
      <div class="pbar-wrap" style="margin-top:10px;">
        <div class="pbar-top"><span>Calories today</span><span id="calTop">&mdash;</span></div>
        <div class="pbar"><div class="pbar-fill gold" id="calBar" style="width:0%"></div></div>
      </div>
    </div>
  </div>

  <!-- PROGRESS -->
  <div class="view" id="v-prog">
    <div class="card">
      <div class="card-h">Weight Trajectory</div>
      <div class="chartbox" id="weightChart"></div>
      <div class="note" id="weightTrendNote" style="margin-top:8px;"></div>
    </div>

    <div class="card">
      <div class="card-h">This Week &middot; Recap</div>
      <div class="statgrid">
        <div class="stat"><div class="v" id="wkWeightΔ">&mdash;</div><div class="l">Weight Δ</div></div>
        <div class="stat"><div class="v" id="wkSessions">&mdash;</div><div class="l">Sessions</div></div>
        <div class="stat"><div class="v" id="wkCal">&mdash;</div><div class="l">Avg Cal</div></div>
        <div class="stat"><div class="v" id="wkPro">&mdash;</div><div class="l">Avg Protein</div></div>
      </div>
    </div>

    <div class="card">
      <div class="card-h">Strength Trend</div>
      <select id="liftSelect" onchange="drawStrength()"></select>
      <div class="chartbox" id="strengthChart" style="margin-top:8px;"></div>
      <div class="note" id="prNote" style="margin-top:8px;"></div>
    </div>

    <div class="card">
      <div class="card-h">Personal Records</div>
      <div id="prList"></div>
    </div>
  </div>

  <!-- SETUP -->
  <div class="view" id="v-setup">
    <div class="card foil">
      <div class="card-h">Creatine Reminder <span class="foil-tag">6:00 PM</span></div>
      <div class="note">PWAs can't push reliable iPhone alerts on their own. This adds a repeating daily 6 PM reminder to your Calendar (with an alert) in one tap.</div>
      <button class="btn gold" onclick="addCreatineReminder()">Add Daily 6 PM Reminder</button>
      <small class="help">Opens an event file. Tap "Add All" when iOS asks. Dose: 3&ndash;5 g creatine monohydrate.</small>
    </div>

    <div class="card">
      <div class="card-h">Lab Note</div>
      <div class="note" id="creatineLabNote"></div>
    </div>

    <div class="card">
