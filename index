   {n:"Cable Tricep Pressdown",s:3,lo:10,hi:10},
   {n:"EZ-Bar Curl",s:3,lo:10,hi:10}]},
 {day:"Cardio + Mobility",rest:false,cardio:true,ex:[]},
 {day:"Lower Heavy B",rest:false,ex:[
   {n:"Trap-Bar Deadlift",s:5,lo:3,hi:5,bone:true},
   {n:"Barbell RDL",s:3,lo:6,hi:6},
   {n:"Leg Press",s:3,lo:8,hi:8},
   {n:"Standing Calf Raise",s:4,lo:12,hi:12}]},
 {day:"Upper Heavy B",rest:false,ex:[
