   {n:"Hammer Iso Shoulder Press",s:3,lo:8,hi:8},
   {n:"Cable Pullovers",s:3,lo:12,hi:12},
   {n:"Seated Lateral Raise",s:4,lo:15,hi:15},
   {n:"Incline DB Curl",s:3,lo:10,hi:10}]},
 {day:"Optional / Rest",rest:true,ex:[]},
 {day:"Rest",rest:true,ex:[]}
];

/* ============ STATE ============ */
var DB={weights:[],nutrition:[],rhr:[],workouts:[],prs:{},readiness:[],oneRM:{},settings:{sheetUrl:""}};
var selDay=null, selFatigue=null, readyPick={sleep:null,energy:null,pain:null};
var timerInt=null, timerLeft=0;

function load(){
  try{var s=localStorage.getItem("healthpad_db");if(s)DB=JSON.parse(s);}catch(e){}
  if(!DB.oneRM||Object.keys(DB.oneRM).length===0){DB.oneRM=Object.assign({},DEFAULT_1RM);}
  if(!DB.settings)DB.settings={sheetUrl:""};
}
function save(){try{localStorage.setItem("healthpad_db",JSON.stringify(DB));}catch(e){}}
function todayStr(){var d=new Date();return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate());}
function pad(n){return n<10?"0"+n:""+n;}
function toast(m){var t=document.getElementById("toast");t.textContent=m;t.classList.add("show");setTimeout(function(){t.classList.remove("show");},1900);}

/* ============ PHASE LOGIC ============ */
function currentPhase(){
  var t=new Date();t.setHours(0,0,0,0);
  for(var i=0;i<PHASES.length;i++){
    var e=new Date(PHASES[i].end+"T23:59:59");
    if(t<=e)return PHASES[i];
  }
  return PHASES[PHASES.length-1];
}
function weekNumber(){
  var t=new Date();t.setHours(0,0,0,0);
  var diff=Math.floor((t-START_DATE)/(1000*60*60*24));
  return Math.max(1,Math.floor(diff/7)+1);
}
function isDeload(){return weekNumber()%6===0;}
function currentSplit(){return currentPhase().split==="HEAVY"?SPLIT_HEAVY:SPLIT_AB;}
function defaultDayIdx(){
  var js=new Date().getDay(); // 0 Sun..6 Sat
  return js===0?6:js-1; // map to Mon=0
}

/* ============ NAV ============ */
function nav(v){
  document.querySelectorAll(".view").forEach(function(x){x.classList.remove("active");});
  document.getElementById("v-"+v).classList.add("active");
  document.querySelectorAll(".navb").forEach(function(b){b.classList.toggle("active",b.dataset.v===v);});
  if(v==="home")renderHome();
  if(v==="train")renderTrain();
  if(v==="log")renderLog();
  if(v==="prog")renderProg();
  if(v==="setup")renderSetup();
  window.scrollTo(0,0);
}

/* ============ HOME ============ */
function renderHome(){
  var t=new Date();t.setHours(0,0,0,0);
  var days=Math.ceil((END_DATE-t)/(1000*60*60*24));
  document.getElementById("cdDays").textContent=days;
  var total=(END_DATE-START_DATE),elapsed=(t-START_DATE);
  var cpct=Math.max(0,Math.min(100,Math.round(elapsed/total*100)));
  document.getElementById("campaignBar").style.width=cpct+"%";
  document.getElementById("campaignPct").textContent=cpct+"%";

  var lw=lastWeight();
  document.getElementById("homeWeight").textContent=lw?lw.toFixed(1):"\u2014";
  document.getElementById("hdrWeight").textContent=lw?lw.toFixed(1):"\u2014";
  var startW=DB.weights.length?DB.weights[0].w:lw;
  document.getElementById("wStart").textContent="Start "+(startW?startW.toFixed(0):"\u2014");
  if(lw){
    var toGo=Math.max(0,lw-GOAL_WEIGHT);
    document.getElementById("homeToGo").textContent=toGo.toFixed(1);
    var lost=startW-lw, need=startW-GOAL_WEIGHT;
    var wpct=need>0?Math.max(0,Math.min(100,Math.round(lost/need*100))):0;
    document.getElementById("weightBar").style.width=wpct+"%";
    // pace
    if(DB.weights.length>=2){
      var first=DB.weights[0], last=DB.weights[DB.weights.length-1];
      var wkSpan=Math.max(1,(new Date(last.d)-new Date(first.d))/(1000*60*60*24*7));
      var rate=(first.w-last.w)/wkSpan;
      var rem=last.w-GOAL_WEIGHT;
      if(rate>0.05){
        var wksLeft=rem/rate;
        var proj=new Date();proj.setDate(proj.getDate()+Math.round(wksLeft*7));
        document.getElementById("paceNote").textContent="Losing ~"+rate.toFixed(2)+" lb/wk. At this pace you reach 200 around "+proj.toLocaleDateString('en-US',{month:'short',year:'numeric'})+". Target rate in fat-loss phase: 1\u20131.5 lb/wk.";
      } else {
        document.getElementById("paceNote").textContent="Not enough downward trend yet \u2014 log daily and watch the weekly average, not the daily number.";
      }
    }
  }

  var ph=currentPhase();
  document.getElementById("phasePill").textContent=ph.name;
  document.getElementById("phasePill").className="phase-pill"+(isDeload()?" deload":"");
  document.getElementById("weekPill").textContent="Week "+weekNumber()+(isDeload()?" \u2022 Deload":"");
  document.getElementById("todayPhaseTag").textContent=ph.key;
  document.getElementById("phaseNote").textContent=ph.note;

  // restore readiness picks UI
  ["sleep","energy","pain"].forEach(function(g){
    document.querySelectorAll('[data-grp="'+g+'"] .choice').forEach(function(c){c.classList.remove("sel","g","w","b");});
  });
  renderMilestones();
}
function renderMilestones(){
  var lw=lastWeight();
  var startW=DB.weights.length?DB.weights[0].w:null;
  var miles=[
    {t:"Begin the campaign",done:DB.weights.length>0||DB.workouts.length>0,d:"Jun 2026"},
    {t:"First 10 lbs down",done:startW&&lw&&(startW-lw)>=10,d:""},
    {t:"Phase 2 \u2014 Strength Build",done:new Date()>=new Date("2026-10-19"),d:"Oct 2026"},
    {t:"Break 220 lbs",done:lw&&lw<=220,d:""},
    {t:"Phase 3 \u2014 Peak",done:new Date()>=new Date("2027-02-08"),d:"Feb 2027"},
    {t:"Reach 200 lbs",done:lw&&lw<=200,d:"Goal"},
    {t:"ADT complete",done:new Date()>=END_DATE,d:"Apr 14 2027"}
  ];
  document.getElementById("mileList").innerHTML=miles.map(function(m){
    return '<div class="mile '+(m.done?"done":"")+'"><span class="dot"></span><span class="mt">'+m.t+'</span><span class="md">'+(m.done?"\u2713 ":"")+m.d+'</span></div>';
  }).join("");
}
function saveReadiness(){
  var r={d:todayStr(),sleep:readyPick.sleep,energy:readyPick.energy,pain:readyPick.pain};
  DB.readiness=DB.readiness.filter(function(x){return x.d!==r.d;});
  DB.readiness.push(r);save();toast("Readiness logged");
}

/* ============ TRAIN ============ */
function renderTrain(){
  var ph=currentPhase();
  document.getElementById("trainPhaseTag").textContent=ph.key+" \u2022 "+ph.name;
  document.getElementById("trainDeload").style.display=isDeload()?"inline-block":"none";
  var split=currentSplit();
  if(selDay===null)selDay=defaultDayIdx();
  var chips=split.map(function(d,i){
    return '<span class="daychip '+(i===selDay?"sel":"")+(d.rest?" rest":"")+'" onclick="pickDay('+i+')">'+d.day+'</span>';
  }).join("");
  document.getElementById("dayChips").innerHTML=chips;
  var d=split[selDay];
  if(d.rest){
    document.getElementById("dayNote").textContent="Rest day. Walk the dog, hit 10k steps, light mobility. Recovery is where adaptation happens \u2014 doubly so on ADT.";
    document.getElementById("workoutArea").innerHTML="";
    return;
  }
  if(d.cardio){
    document.getElementById("dayNote").textContent="Zone 2 cardio (conversational pace) 40\u201350 min plus core and mobility. Steer by the talk test, not heart rate \u2014 phentermine inflates the number.";
    document.getElementById("workoutArea").innerHTML='<div class="card"><div class="card-h">Conditioning</div><label class="fld">Minutes Zone 2</label><input type="number" id="cardioMin" inputmode="numeric" placeholder="45"><div class="note" style="margin-top:8px;">Logged with the session when you tap Save.</div></div>';
    return;
  }
  document.getElementById("dayNote").textContent="Working % of 1RM this phase: "+Math.round(ph.pct[0]*100)+"\u2013"+Math.round(ph.pct[1]*100)+"% \u2022 target RPE "+ph.rpe+". "+(isDeload()?"DELOAD: cut to ~50% of the sets shown.":"");
  var html="";
  d.ex.forEach(function(ex,ei){
    var orm=DB.oneRM[ex.n]||0;
    var loLoad=orm?Math.round(orm*ph.pct[0]/5)*5:0;
    var hiLoad=orm?Math.round(orm*ph.pct[1]/5)*5:0;
    var loadStr=orm?("~"+loLoad+(loLoad!==hiLoad?"\u2013"+hiLoad:"")+" lb"):"set by feel";
    var rec=overloadRec(ex.n,ex.hi);
    var sets=isDeload()?Math.max(1,Math.ceil(ex.s/2)):ex.s;
    var rows="";
    var last=lastSetData(ex.n);
    for(var si=0;si<sets;si++){
      var pw=last&&last[si]?last[si].w:"";
      rows+='<div class="setrow"><span class="sn">'+(si+1)+'</span>'+
        '<input type="number" inputmode="decimal" placeholder="lb" data-ex="'+ei+'" data-set="'+si+'" data-f="w" value="'+(pw||"")+'">'+
        '<input type="number" inputmode="numeric" placeholder="reps" data-ex="'+ei+'" data-set="'+si+'" data-f="r">'+
        '<input type="number" inputmode="decimal" placeholder="RPE" data-ex="'+ei+'" data-set="'+si+'" data-f="rpe">'+
        '</div>';
    }
    html+='<div class="ex" data-name="'+ex.n+'">'+
      '<div class="ex-h" onclick="toggleEx(this)">'+
        '<div><div class="ex-name">'+ex.n+(ex.bone?' <span class="pill bone">Bone</span>':'')+'</div>'+
        '<div class="ex-target">'+sets+' \u00D7 '+(ex.lo===ex.hi?ex.lo:ex.lo+"\u2013"+ex.hi)+' &middot; '+loadStr+'</div>'+
        (rec?'<div class="ex-rec">\u25B2 '+rec+'</div>':'')+
        '</div><span style="color:var(--ink-faint);">\u25BE</span>'+
      '</div>'+
      '<div class="ex-body">'+
        '<div class="setlbl"><span></span><span>Weight</span><span>Reps</span><span>RPE</span></div>'+
        rows+
        (ex.bone?'<div class="overload">Bone-priority lift. Keep this even on low days \u2014 reduce load before skipping.</div>':'')+
      '</div>'+
    '</div>';
  });
  document.getElementById("workoutArea").innerHTML=html;
}
function pickDay(i){selDay=i;renderTrain();}
function toggleEx(el){el.parentNode.querySelector(".ex-body").classList.toggle("open");}

function overloadRec(name,hi){
  // if last logged session hit top reps on all sets -> recommend increase
  var hist=DB.workouts.filter(function(w){return w.ex&&w.ex[name];}).slice(-1);
  if(!hist.length)return null;
  var sets=hist[0].ex[name];
  if(!sets||!sets.length)return null;
  var allTop=sets.every(function(s){return s.r&&s.r>=hi;});
  if(allTop)return "Hit top reps last time \u2014 add load";
  return null;
}
function lastSetData(name){
  var hist=DB.workouts.filter(function(w){return w.ex&&w.ex[name];}).slice(-1);
  return hist.length?hist[0].ex[name]:null;
}
function setFatigue(v){selFatigue=v;}

function saveWorkout(){
  var split=currentSplit();var d=split[selDay];
  var rec={d:todayStr(),day:d.day,phase:currentPhase().key,week:weekNumber(),fatigue:selFatigue,ex:{}};
  if(d.cardio){
    var cm=document.getElementById("cardioMin");
    rec.cardio=cm?parseInt(cm.value)||0:0;
  } else {
    var inputs=document.querySelectorAll("#workoutArea input[data-ex]");
    var temp={};
    inputs.forEach(function(inp){
      var ei=inp.dataset.ex,si=inp.dataset.set,f=inp.dataset.f;
      var exName=d.ex[ei].n;
      if(!temp[exName])temp[exName]={};
      if(!temp[exName][si])temp[exName][si]={};
      var val=parseFloat(inp.value);
      if(!isNaN(val))temp[exName][si][f]=val;
    });
    Object.keys(temp).forEach(function(name){
      var arr=Object.keys(temp[name]).sort().map(function(k){return temp[name][k];}).filter(function(s){return s.w||s.r;});
      if(arr.length){rec.ex[name]=arr;updatePR(name,arr);}
    });
  }
  // remove existing same-day same-split entry
  DB.workouts=DB.workouts.filter(function(w){return !(w.d===rec.d&&w.day===rec.day);});
  DB.workouts.push(rec);
  save();toast("Session saved to the ledger");
  trySheetSync();
}
function e1rm(w,r){return r<=1?w:Math.round(w*(1+r/30));}
function updatePR(name,sets){
  sets.forEach(function(s){
    if(s.w&&s.r){
      var est=e1rm(s.w,s.r);
      if(!DB.prs[name]||est>DB.prs[name].e1rm){
        DB.prs[name]={w:s.w,r:s.r,e1rm:est,d:todayStr()};
      }
    }
  });
}

/* ============ LOG ============ */
function renderLog(){
  var ph=currentPhase();
  document.getElementById("calTargetTag").textContent="Target "+ph.cal+" kcal";
  var lw=lastWeight();
  document.getElementById("weightEcho").textContent=lw?("Last recorded: "+lw.toFixed(1)+" lb. To goal: "+(lw-GOAL_WEIGHT).toFixed(1)+" lb."):"No weight logged yet.";
  var nt=todayNutrition();
  var pro=nt?nt.pro:0,cal=nt?nt.cal:0;
  document.getElementById("proTop").textContent=(pro||0)+" / "+PROTEIN_TARGET+" g";
  document.getElementById("proBar").style.width=Math.min(100,(pro/PROTEIN_TARGET*100))+"%";
  document.getElementById("calTop").textContent=(cal||0)+" / "+ph.cal;
  document.getElementById("calBar").style.width=Math.min(100,(cal/ph.cal*100))+"%";
}
function saveWeight(){
  var v=parseFloat(document.getElementById("inWeight").value);
  if(isNaN(v)){toast("Enter a weight");return;}
  DB.weights=DB.weights.filter(function(x){return x.d!==todayStr();});
  DB.weights.push({d:todayStr(),w:v});
  DB.weights.sort(function(a,b){return new Date(a.d)-new Date(b.d);});
  save();document.getElementById("inWeight").value="";renderLog();toast("Weight recorded");trySheetSync();
}
function saveRHR(){
  var v=parseInt(document.getElementById("inRHR").value);
  if(isNaN(v)){toast("Enter RHR");return;}
  DB.rhr=DB.rhr.filter(function(x){return x.d!==todayStr();});
  DB.rhr.push({d:todayStr(),v:v});save();document.getElementById("inRHR").value="";toast("RHR recorded");
}
function saveNutrition(){
  var cal=parseInt(document.getElementById("inCal").value)||0;
  var pro=parseInt(document.getElementById("inPro").value)||0;
  var carb=parseInt(document.getElementById("inCarb").value)||0;
  var fat=parseInt(document.getElementById("inFat").value)||0;
  if(!cal&&!pro){toast("Enter your numbers");return;}
  DB.nutrition=DB.nutrition.filter(function(x){return x.d!==todayStr();});
  DB.nutrition.push({d:todayStr(),cal:cal,pro:pro,carb:carb,fat:fat});
  save();renderLog();toast("Day recorded");trySheetSync();
  document.getElementById("inCal").value="";document.getElementById("inPro").value="";
  document.getElementById("inCarb").value="";document.getElementById("inFat").value="";
}
function lastWeight(){return DB.weights.length?DB.weights[DB.weights.length-1].w:null;}
function todayNutrition(){var t=todayStr();for(var i=0;i<DB.nutrition.length;i++)if(DB.nutrition[i].d===t)return DB.nutrition[i];return null;}

/* ============ PROGRESS ============ */
function renderProg(){
  drawWeight();
  weeklyRecap();
  populateLifts();
  drawStrength();
  renderPRs();
}
function drawWeight(){
  var box=document.getElementById("weightChart");
  if(DB.weights.length<2){box.innerHTML='<div class="chart-empty">Log at least two weigh-ins to see your trajectory.</div>';document.getElementById("weightTrendNote").textContent="";return;}
  var data=DB.weights.slice();
  var ws=data.map(function(x){return x.w;});
  var minW=Math.min(GOAL_WEIGHT-2,Math.min.apply(null,ws));
  var maxW=Math.max.apply(null,ws);
  var W=520,H=200,pad=30;
  var n=data.length;
  function x(i){return pad+(W-2*pad)*(n===1?0.5:i/(n-1));}
  function y(w){return pad+(H-2*pad)*(1-(w-minW)/(maxW-minW||1));}
  var pts=data.map(function(d,i){return x(i)+","+y(d.w);}).join(" ");
  var goalY=y(GOAL_WEIGHT);
  var svg='<svg viewBox="0 0 '+W+' '+H+'">';
  svg+='<line x1="'+pad+'" y1="'+goalY+'" x2="'+(W-pad)+'" y2="'+goalY+'" stroke="#8a6a28" stroke-width="1.5" stroke-dasharray="5 4"/>';
  svg+='<text x="'+(W-pad)+'" y="'+(goalY-5)+'" text-anchor="end" font-size="11" fill="#8a6a28">Goal 200</text>';
  svg+='<polyline points="'+pts+'" fill="none" stroke="#6e1f2e" stroke-width="2.5"/>';
  data.forEach(function(d,i){svg+='<circle cx="'+x(i)+'" cy="'+y(d.w)+'" r="3" fill="#6e1f2e"/>';});
  svg+='<text x="'+pad+'" y="'+(H-8)+'" font-size="10" fill="#8a7c69">'+data[0].d.slice(5)+'</text>';
  svg+='<text x="'+(W-pad)+'" y="'+(H-8)+'" text-anchor="end" font-size="10" fill="#8a7c69">'+data[n-1].d.slice(5)+'</text>';
  svg+='</svg>';
  box.innerHTML=svg;
  // 7-day avg trend
  var note=weeklyAvgTrend();
  document.getElementById("weightTrendNote").textContent=note;
}
function weeklyAvgTrend(){
  if(DB.weights.length<4)return "";
  var n=DB.weights.length;
  var recent=DB.weights.slice(Math.max(0,n-7));
  var prev=DB.weights.slice(Math.max(0,n-14),Math.max(0,n-7));
  if(!prev.length)return "";
  var avg=function(a){return a.reduce(function(s,x){return s+x.w;},0)/a.length;};
  var diff=avg(recent)-avg(prev);
  return "7-day average "+(diff<0?"down":"up")+" "+Math.abs(diff).toFixed(2)+" lb vs the prior week. The weekly average is the number to trust \u2014 ignore daily water swings.";
}
function weeklyRecap(){
  var now=new Date();var weekAgo=new Date();weekAgo.setDate(now.getDate()-7);
  var inWk=function(d){return new Date(d)>=weekAgo;};
  var wW=DB.weights.filter(function(x){return inWk(x.d);});
  var wΔ=wW.length>=2?(wW[wW.length-1].w-wW[0].w):null;
  document.getElementById("wkWeightΔ").textContent=wΔ===null?"\u2014":(wΔ>0?"+":"")+wΔ.toFixed(1);
  var sess=DB.workouts.filter(function(x){return inWk(x.d)&&Object.keys(x.ex||{}).length;}).length;
  document.getElementById("wkSessions").textContent=sess;
  var nut=DB.nutrition.filter(function(x){return inWk(x.d);});
  var avgC=nut.length?Math.round(nut.reduce(function(s,x){return s+x.cal;},0)/nut.length):null;
  var avgP=nut.length?Math.round(nut.reduce(function(s,x){return s+x.pro;},0)/nut.length):null;
  document.getElementById("wkCal").textContent=avgC===null?"\u2014":avgC;
  document.getElementById("wkPro").textContent=avgP===null?"\u2014":avgP+"g";
}
function populateLifts(){
  var sel=document.getElementById("liftSelect");
  var lifts=Object.keys(DB.prs);
  if(!lifts.length){sel.innerHTML='<option>No lifts logged yet</option>';return;}
  var cur=sel.value;
  sel.innerHTML=lifts.map(function(l){return '<option'+(l===cur?' selected':'')+'>'+l+'</option>';}).join("");
}
function drawStrength(){
  var box=document.getElementById("strengthChart");
  var lift=document.getElementById("liftSelect").value;
  var series=[];
  DB.workouts.forEach(function(w){
    if(w.ex&&w.ex[lift]){
      var best=0;w.ex[lift].forEach(function(s){if(s.w&&s.r){var e=e1rm(s.w,s.r);if(e>best)best=e;}});
      if(best)series.push({d:w.d,e:best});
    }
  });
  if(series.length<2){box.innerHTML='<div class="chart-empty">Log this lift across at least two sessions to chart estimated strength.</div>';document.getElementById("prNote").textContent="";return;}
  var es=series.map(function(x){return x.e;});
  var minE=Math.min.apply(null,es)*0.96,maxE=Math.max.apply(null,es)*1.02;
  var W=520,H=180,pad=30,n=series.length;
  function x(i){return pad+(W-2*pad)*(i/(n-1));}
  function y(e){return pad+(H-2*pad)*(1-(e-minE)/(maxE-minE||1));}
  var pts=series.map(function(d,i){return x(i)+","+y(d.e);}).join(" ");
  var svg='<svg viewBox="0 0 '+W+' '+H+'">';
  svg+='<polyline points="'+pts+'" fill="none" stroke="#6e1f2e" stroke-width="2.5"/>';
  series.forEach(function(d,i){svg+='<circle cx="'+x(i)+'" cy="'+y(d.e)+'" r="3" fill="#8a6a28"/>';});
  svg+='</svg>';
  box.innerHTML=svg;
  var pr=DB.prs[lift];
  if(pr)document.getElementById("prNote").textContent="Best: "+pr.w+" lb \u00D7 "+pr.r+" (est 1RM "+pr.e1rm+" lb) on "+pr.d+".";
}
function renderPRs(){
  var keys=Object.keys(DB.prs);
  if(!keys.length){document.getElementById("prList").innerHTML='<div class="note">No records yet. Log a session to set your first.</div>';return;}
  keys.sort();
  document.getElementById("prList").innerHTML=keys.map(function(k){
    var p=DB.prs[k];
    return '<div class="mile done"><span class="dot"></span><span class="mt" style="color:var(--ink);font-size:13px;">'+k+'</span><span class="md">'+p.w+'\u00D7'+p.r+' \u2022 e1RM '+p.e1rm+'</span></div>';
  }).join("");
}

/* ============ SETUP ============ */
function renderSetup(){
  document.getElementById("creatineLabNote").innerHTML="Before any bloodwork, remind your oncology team you take creatine. It raises serum creatinine on labs in a benign way, and you don't want that misread as reduced kidney function. The Iso-100 and Premier shakes add to that creatinine load too \u2014 same harmless effect, worth one mention.";
  // 1RM editor
  var html="";
  Object.keys(DEFAULT_1RM).forEach(function(k){
    var v=DB.oneRM[k]||0;
    html+='<label class="fld">'+k+(v===0?' <span class="pill bone">set after P0</span>':'')+'</label><input type="number" inputmode="numeric" data-orm="'+k+'" value="'+(v||"")+'" placeholder="lb">';
  });
  document.getElementById("oneRMList").innerHTML=html;
  document.getElementById("inSheetUrl").value=DB.settings.sheetUrl||"";
  // phase overview
  document.getElementById("phaseOverview").innerHTML=PHASES.map(function(p){
    return '<div style="margin-bottom:11px;"><span class="phase-pill">'+p.name+'</span> <span class="pill line">'+p.start.slice(5)+' \u2192 '+p.end.slice(5)+'</span><div class="note" style="margin-top:5px;">'+Math.round(p.pct[0]*100)+'\u2013'+Math.round(p.pct[1]*100)+'% 1RM \u2022 RPE '+p.rpe+' \u2022 '+p.cal+' kcal</div></div>';
  }).join("");
}
function saveOneRMs(){
  document.querySelectorAll('[data-orm]').forEach(function(inp){
    var v=parseFloat(inp.value);DB.oneRM[inp.dataset.orm]=isNaN(v)?0:v;
  });
  save();toast("1RMs saved");
}
function saveSheetUrl(){
  DB.settings.sheetUrl=document.getElementById("inSheetUrl").value.trim();save();toast("URL saved");
}
function addCreatineReminder(){
  var ics="BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//TheLedger//Creatine//EN\r\nCALSCALE:GREGORIAN\r\nBEGIN:VEVENT\r\nUID:creatine-ledger-"+Date.now()+"@ledger\r\nDTSTART:20260614T180000\r\nRRULE:FREQ=DAILY\r\nSUMMARY:Take Creatine (3-5g)\r\nDESCRIPTION:Daily creatine monohydrate. Stay hydrated.\r\nBEGIN:VALARM\r\nTRIGGER:PT0M\r\nACTION:DISPLAY\r\nDESCRIPTION:Take Creatine (3-5g)\r\nEND:VALARM\r\nEND:VEVENT\r\nEND:VCALENDAR";
  var blob=new Blob([ics],{type:"text/calendar"});
  var url=URL.createObjectURL(blob);
  var a=document.createElement("a");a.href=url;a.download="creatine-reminder.ics";document.body.appendChild(a);a.click();
  setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(url);},500);
  toast("Opening reminder \u2014 tap Add All");
}
function exportData(){
  var blob=new Blob([JSON.stringify(DB,null,2)],{type:"application/json"});
  var url=URL.createObjectURL(blob);var a=document.createElement("a");
  a.href=url;a.download="healthpad-backup-"+todayStr()+".json";document.body.appendChild(a);a.click();
  setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(url);},500);
  toast("Backup exported");
}
function importData(e){
  var f=e.target.files[0];if(!f)return;var r=new FileReader();
  r.onload=function(){try{DB=JSON.parse(r.result);save();toast("Data imported");nav("home");}catch(err){toast("Invalid file");}};
  r.readAsText(f);
}

/* ============ SHEETS SYNC ============ */
function trySheetSync(){if(DB.settings.sheetUrl)syncNow(true);}
function syncNow(quiet){
  if(!DB.settings.sheetUrl){if(!quiet)toast("Add your Sheets URL first");return;}
  var note=document.getElementById("syncNote");
  fetch(DB.settings.sheetUrl,{method:"POST",mode:"no-cors",headers:{"Content-Type":"text/plain"},body:JSON.stringify(DB)})
   .then(function(){if(note)note.textContent="Last sync attempt: "+new Date().toLocaleTimeString();if(!quiet)toast("Synced to Sheets");})
   .catch(function(){if(!quiet)toast("Sync failed \u2014 check URL");});
}

/* ============ TIMER ============ */
function startTimer(sec){
  timerLeft=sec;document.getElementById("restTimer").classList.add("show");updTimer();
  if(timerInt)clearInterval(timerInt);
  timerInt=setInterval(function(){timerLeft--;updTimer();if(timerLeft<=0){stopTimer();try{navigator.vibrate&&navigator.vibrate(400);}catch(e){}toast("Rest complete");}},1000);
}
function updTimer(){var m=Math.floor(timerLeft/60),s=timerLeft%60;document.getElementById("timerT").textContent=m+":"+pad(s);}
function stopTimer(){if(timerInt)clearInterval(timerInt);timerInt=null;document.getElementById("restTimer").classList.remove("show");}

/* ============ CHOICE HANDLERS ============ */
document.addEventListener("click",function(e){
  var c=e.target.closest(".choice");if(!c)return;
  var grp=c.parentNode.dataset.grp;
  c.parentNode.querySelectorAll(".choice").forEach(function(x){x.classList.remove("sel","g","w","b");});
  var v=c.dataset.v;
  var cls="sel";
  if(["good","high","none"].indexOf(v)>=0)cls="sel g";
  else if(["mod","ok","some"].indexOf(v)>=0)cls="sel w";
  else if(["low","poor","lots"].indexOf(v)>=0)cls="sel b";
  c.className="choice "+cls;
  if(grp==="fatigue"){
    selFatigue=v;
    var msg={good:"Push the prescribed loads and RPE.",mod:"Hold loads, trim a set or two if needed.",low:"Drop weight 10\u201315%, keep the movement. Showing up at 70% still counts."};
    document.getElementById("fatigueNote").textContent=msg[v]||"";
  } else if(grp&&readyPick.hasOwnProperty(grp)){
    readyPick[grp]=v;
  }
});

